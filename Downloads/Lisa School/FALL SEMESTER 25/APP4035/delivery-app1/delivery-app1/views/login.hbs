<div class="row justify-content-center align-items-center min-vh-50">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow-lg border-0">
      <div class="card-body p-4">
        <div class="text-center mb-4">
          <!-- Animated DeliverEase Logo -->
          <video autoplay loop muted playsinline class="mb-3" style="height: 80px; width: auto;">
            <source src="/videos/logo-animation.mp4" type="video/mp4">
            <!-- Fallback image if video doesn't load -->
            <img src="/images/logo-static.png" alt="DeliverEase Logo" style="height: 80px;">
          </video>
          <h2 class="card-title fw-bold text-primary">DeliverEase</h2>
          <p class="text-muted">Sign in to your account</p>
        </div>

        {{#if error}}
          <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <div>{{error}}</div>
          </div>
        {{/if}}

        <form method="POST" action="/login">
          <div class="mb-3">
            <label for="username" class="form-label fw-bold">
              <i class="fas fa-user me-1 text-primary"></i>Username
            </label>
            <div class="input-group">
              <span class="input-group-text bg-light">
                <i class="fas fa-user text-muted"></i>
              </span>
              <input id="username" name="username" class="form-control" 
                placeholder="Enter your username" required autofocus />
            </div>
          </div>

          <div class="mb-4">
            <label for="password" class="form-label fw-bold">
              <i class="fas fa-lock me-1 text-primary"></i>Password
            </label>
            <div class="input-group">
              <span class="input-group-text bg-light">
                <i class="fas fa-lock text-muted"></i>
              </span>
              <input id="password" name="password" type="password" class="form-control" 
                placeholder="Enter your password" required />
            </div>
          </div>

          <button class="btn btn-primary w-100 py-2 fw-bold">
            <i class="fas fa-sign-in-alt me-2"></i>Sign In
          </button>
        </form>
      </div>
    </div>
  </div>
</div>