<div class="card shadow-sm border-0">
  <div class="card-header bg-secondary text-white">
    <h1 class="h3 mb-0">
      <i class="fas fa-archive me-2"></i>Archived Deliveries
    </h1>
  </div>
  <div class="card-body">
    {{!-- Filter Form --}}
    <div class="card mb-4 bg-light">
      <div class="card-body">
        <form method="GET" action="/archived" class="row g-3 align-items-end">
          <div class="col-md-2">
            <label class="form-label small fw-bold">ID</label>
            <input type="text" name="id" value="{{query.id}}" class="form-control form-control-sm" placeholder="ID">
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-bold">Recipient</label>
            <input type="text" name="recipient" value="{{query.recipient}}" class="form-control form-control-sm" placeholder="Recipient">
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-bold">Address</label>
            <input type="text" name="address" value="{{query.address}}" class="form-control form-control-sm" placeholder="Address">
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-bold">Item</label>
            <input type="text" name="item" value="{{query.item}}" class="form-control form-control-sm" placeholder="Item">
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-bold">Driver</label>
            <input type="text" name="driver" value="{{query.driver}}" class="form-control form-control-sm" placeholder="Driver">
          </div>

          <div class="col-md-2">
            <label class="form-label small fw-bold">Date</label>
            <input type="date" name="date" value="{{query.date}}" class="form-control form-control-sm">
          </div>

          <div class="col-md-2">
            <button class="btn btn-primary w-100" type="submit">
              <i class="fas fa-filter me-1"></i>Filter
            </button>
          </div>
        </form>
      </div>
    </div>

    {{#if deliveries.length}}
    <div class="table-responsive shadow-sm rounded">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-secondary">
          <tr>
            <th><i class="fas fa-hashtag me-1"></i>ID</th>
            <th><i class="fas fa-user me-1"></i>Recipient</th>
            <th><i class="fas fa-map-marker-alt me-1"></i>Address</th>
            <th><i class="fas fa-box me-1"></i>Item</th>
            <th><i class="fas fa-id-card me-1"></i>Driver</th>
            <th><i class="fas fa-status me-1"></i>Status</th>
            <th><i class="fas fa-calendar me-1"></i>Created At</th>
            <th><i class="fas fa-archive me-1"></i>Archived At</th>
            <th class="text-center"><i class="fas fa-cogs me-1"></i>Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each deliveries}}
          <tr>
            <td><span class="badge bg-secondary">#{{id}}</span></td>
            <td class="fw-bold">{{recipient}}</td>
            <td>
              <small class="text-muted">
                <i class="fas fa-map-pin me-1"></i>{{address}}
              </small>
            </td>
            <td>{{item}}</td>
            <td>
              <span class="badge bg-light text-dark">
                <i class="fas fa-user me-1"></i>{{driver}}
              </span>
            </td>
            <td>
              <span class="badge bg-success">
                <i class="fas fa-check-circle me-1"></i>Delivered
              </span>
            </td>
            <td>
              <small class="text-muted">{{formatDate createdAt}}</small>
            </td>
            <td>
              <small class="text-muted">{{formatDate archivedAt}}</small>
            </td>
            <td class="text-center">
              <div class="btn-group btn-group-sm" role="group">
                <form action="/restore-archived/{{id}}" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-outline-success" title="Restore Delivery">
                    <i class="fas fa-undo"></i>
                  </button>
                </form>
                <form action="/delete-archived/{{id}}" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-outline-danger" 
                    onclick="return confirm('Permanently delete archived delivery #{{id}}?')"
                    title="Delete Permanently">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
    <div class="text-center py-5">
      <i class="fas fa-archive fa-3x text-muted mb-3"></i>
      <h4 class="text-muted">No Archived Deliveries</h4>
      <p class="text-muted">There are no archived deliveries matching your criteria.</p>
    </div>
    {{/if}}
  </div>
</div>