<div class="row">
  <div class="col-12">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-primary text-white">
        <h1 class="h3 mb-0">
          <i class="fas fa-tachometer-alt me-2"></i>Welcome, {{user}}!
        </h1>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-8">
            {{!-- Removed the redundant message --}}
          </div>
          <div class="col-md-4 text-end">
            <div class="badge bg-light text-dark p-2">
              <i class="fas fa-user-tag me-1"></i>
              {{session.role}}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{{#ifIn session.role "admin,manager"}}
{{!-- Admin/Manager Dashboard --}}
<div class="row mt-4">
  <div class="col-md-6">
    <div class="card bg-primary text-white shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h3 class="card-title h1">{{stats.totalDeliveries}}</h3>
            <p class="card-text mb-0">Total Deliveries</p>
          </div>
          <div class="align-self-center">
            <i class="fas fa-truck-loading fa-2x opacity-75"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{{else}}
{{!-- Driver Dashboard --}}
<div class="row mt-4">
  <div class="col-md-6">
    <div class="card bg-success text-white shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <h3 class="card-title h1">{{deliveriesCount}}</h3>
            <p class="card-text mb-0">Assigned to You</p>
          </div>
          <div class="align-self-center">
            <i class="fas fa-clipboard-list fa-2x opacity-75"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{{/ifIn}}